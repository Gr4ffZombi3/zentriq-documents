FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-value

# MariaDB
# MARIADB_ROOT_PASSWORD/DATABASE/USER/PASSWORD werden NUR von docker-compose.yml gelesen
# (lokale Dev-DB im Container). Auf dem Produktionsserver (natives MariaDB via
# deploy/install.sh) ist ausschliesslich DATABASE_URL relevant - die einzige Variable,
# die config.py tatsaechlich liest.
MARIADB_ROOT_PASSWORD=change-me
MARIADB_DATABASE=zentriq_documents
MARIADB_USER=zentriq
MARIADB_PASSWORD=change-me
DATABASE_URL=mysql+pymysql://zentriq:change-me@localhost:3306/zentriq_documents

# Redis / Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# OCR
# Windows-Beispiel: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
OCR_MIN_CONFIDENCE=60
OCR_MIN_TEXT_LENGTH=20

# Uploads
UPLOAD_FOLDER=storage/uploads
MAX_UPLOAD_MB=25

# Sessions
# In Produktion (HTTPS) auf true setzen, damit das Session-Cookie nur ueber HTTPS gesendet wird.
SESSION_COOKIE_SECURE=false

# Deployment / URL-Aufloesung fuer nginx-Checks
PUBLIC_HOST=
PUBLIC_URL=
