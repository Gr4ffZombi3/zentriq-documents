# Beispiel-Konfiguration - an tatsaechliche Domain/TLS-Setup anpassen und nach
# /etc/nginx/sites-available/zentriq kopieren (nicht automatisch von deploy.sh verwaltet).
server {
    listen 80;
    server_name documents.example.com;

    client_max_body_size 30M;

    location /static/ {
        alias /opt/zentriq-documents/app/static/;
    }

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
